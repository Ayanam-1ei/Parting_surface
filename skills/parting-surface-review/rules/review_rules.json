{
  "schema_version": "2.0",
  "sharp_steel_candidate_policy": {
    "near_product_max_mm": 0.1,
    "valid_curve_radius_max_mm": 1000000.0,
    "narrow_nonplanar_face_max_mm": 1.0,
    "confirmed_max_edge_length_mm": 0.1,
    "confirmed_min_angle_deg": 1.0,
    "confirmed_max_angle_deg": 45.0,
    "candidate_max_edge_length_mm": 1.5,
    "candidate_min_angle_deg": 0.5,
    "candidate_max_angle_deg": 15.0,
    "cluster_radius_mm": 2.0,
    "max_reported_candidates": 30
  },
  "rules": [
    {
      "id": "PL-001",
      "name": "分型面复杂度",
      "description": "平面分型优先；复杂曲面必须结合产品结构说明必要性",
      "severity": "WARN",
      "consequence": "加工、配模和维护成本上升",
      "category": "parting_line"
    },
    {
      "id": "PL-002",
      "name": "最大轮廓分型位置",
      "description": "需结合开模方向验证分型位置是否位于最大可见轮廓",
      "field": "parting_line.is_at_max_contour",
      "operator": "==",
      "threshold": true,
      "severity": "ERROR",
      "consequence": "可能形成倒扣、拉伤或尖钢",
      "category": "parting_line"
    },
    {
      "id": "SS-GEO-001",
      "name": "尖钢确定性几何候选",
      "description": "同时满足贴近产品、短边/微边、可测夹角和窄非平面面时标记风险",
      "severity": "ERROR",
      "consequence": "可能形成承压尖钢、碎面或局部薄弱钢料",
      "category": "sharp_steel_geometry"
    },
    {
      "id": "SS-001",
      "name": "尖钢最小钢厚",
      "description": "真实钢料最小厚度须不小于 2.0 mm",
      "field": "sharp_steels[*].thickness_mm",
      "operator": ">=",
      "threshold": 2.0,
      "severity": "ERROR",
      "consequence": "崩裂或模具寿命下降",
      "category": "sharp_steel",
      "per_item": true
    },
    {
      "id": "SS-002",
      "name": "钢料细长比",
      "description": "真实钢料高度/厚度比须不大于 3.0",
      "field": "sharp_steels[*].aspect_ratio",
      "operator": "<=",
      "threshold": 3.0,
      "severity": "ERROR",
      "consequence": "强度不足或受压变形",
      "category": "sharp_steel",
      "per_item": true
    },
    {
      "id": "SS-003",
      "name": "真实钢料圆角",
      "description": "应力集中处真实钢料圆角须不小于 0.5 mm",
      "field": "sharp_steels[*].edge_radius_mm",
      "operator": ">=",
      "threshold": 0.5,
      "severity": "WARN",
      "consequence": "应力集中或崩缺",
      "category": "sharp_steel",
      "per_item": true
    },
    {
      "id": "UC-001",
      "name": "倒扣检测",
      "description": "需基于开模方向验证产品可见性与倒扣",
      "field": "undercuts",
      "operator": "length_zero",
      "threshold": 0,
      "severity": "ERROR",
      "consequence": "无法正常脱模",
      "category": "undercut"
    }
  ],
  "solution_priority": [
    {
      "rank": 1,
      "name": "局部分型面重构",
      "description": "优先消除微小边、狭窄碎面和不连续过渡"
    },
    {
      "rank": 2,
      "name": "局部镶件",
      "description": "分型面不可调整时，把薄弱区域设计为可更换镶件"
    },
    {
      "rank": 3,
      "name": "侧向机构",
      "description": "产品结构导致直接分型不可行时再评估滑块或斜顶"
    }
  ]
}
